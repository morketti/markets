# Markets frontend — build-time environment variables.
#
# Both vars are required at Vite build time so the static bundle has the
# right raw.githubusercontent.com URL hardcoded — there is no runtime
# config.json (would add an extra fetch + complicate Vercel previews).
#
# In Vercel: set these in Project Settings → Environment Variables for
# Production + Preview. Locally: copy this file to .env.local and edit.

# GitHub username/org that owns the repo holding data/YYYY-MM-DD/*.json.
VITE_GH_USER=your-github-username

# Repository name (the same repo this frontend lives in).
VITE_GH_REPO=markets
